    font-size: 13.5px;
    line-height: 1.55;
  }

  .page {
    max-width: 820px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 210px 1fr;
    min-height: 100vh;
    background: #fff;
    position: relative;
  }

  /* Single continuous amber divider — starts 10px from the top */
  .page::before {
    content: '';
    position: absolute;
    left: 210px;
    top: 20px;
    bottom: 0;
    width: 1px;
    background: #E8A020;
    pointer-events: none;
    z-index: 1;
  }

  /* LEFT SIDEBAR */
  .sidebar {
    padding: 36px 24px 36px 32px;
  }

  .logo { margin-bottom: 20px; }
  .logo svg { width: 62px; height: 62px; }

  .name {
    font-size: 30px;
    font-weight: 400;
    line-height: 1.18;
    color: #78A8EF;
    margin-bottom: 28px;
  }
  .name-main {
    font-family: 'Inria Serif', serif;
    font-style: italic;
    font-weight: 700;
    display: block;
  }
  .name-nick {
    font-family: 'Instrument Sans', sans-serif;
    font-style: italic;
    font-weight: 500;
    display: block;
  }

  .sidebar-heading {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #E07030;
    margin-bottom: 10px;
    margin-top: 24px;
  }

  .contact-list { list-style: none; margin-bottom: 4px; }
  .contact-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    color: #444;
    margin-bottom: 7px;
  }
  .contact-list li svg {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    color: #888;
  }
  .contact-list li a { color: #444; text-decoration: none; }
  .contact-list li a:hover { color: #E07030; }

  .portfolio-link {
    font-size: 12.5px;
    color: #444;
    text-decoration: underline;
    text-decoration-color: #ccc;
    display: inline-block;
    margin-bottom: 4px;
  }
  .portfolio-link:hover { color: #E07030; }

  .skills-list { list-style: none; }
  .skills-list li { font-size: 13px; color: #333; margin-bottom: 4px; }

  /* RIGHT MAIN */
  .main { padding: 36px 36px 36px 30px; }

  .summary {
    margin-bottom: 30px;
    font-size: 13.5px;
    color: #333;
    line-height: 1.6;
  }
  .summary p + p { margin-top: 6px; }

  .section-heading {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #E07030;
    margin-bottom: 16px;
    margin-top: 28px;
  }
  .section-heading:first-child { margin-top: 0; }

  .exp-entry {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0 30px;
    margin-bottom: 22px;
  }

  .exp-year { font-size: 12px; color: #888; padding-top: 1px; white-space: nowrap; }

  .exp-company { font-size: 13.5px; font-weight: 600; color: #222; margin-bottom: 1px; }
  .exp-company span { font-weight: 400; color: #666; }

  .exp-role {
    font-family: 'Lora', serif;
    font-size: 14.5px;
    font-weight: 400;
    color: #78A8EF;
    margin-bottom: 6px;
  }

  .exp-bullets { list-style: none; padding: 0; }
  .exp-bullets li {
    font-size: 13px;
    color: #444;
    padding-left: 14px;
    position: relative;
    margin-bottom: 3px;
    line-height: 1.55;
  }
  .exp-bullets li::before { content: '•'; position: absolute; left: 2px; color: #aaa; }

  .edu-entry {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0 30px;
    margin-bottom: 16px;
  }
  .edu-year { font-size: 12px; color: #888; padding-top: 1px; white-space: nowrap; }
  .edu-school { font-size: 13.5px; font-weight: 700; color: #222; line-height: 1.4; }
  .edu-degree { font-size: 13px; color: #555; margin-top: 1px; }

  @media (max-width: 600px) {
    .page { grid-template-columns: 1fr; }
    .sidebar { border-right: none; border-bottom: 1px solid #e8e8e8; }
    .exp-entry, .edu-entry { grid-template-columns: 1fr; }
  }
</style>
